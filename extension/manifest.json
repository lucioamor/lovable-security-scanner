{
  "manifest_version": 3,
  "name": "Lovable Portfolio Audit",
  "version": "1.0.0",
  "description": "Audit your Lovable.dev projects for exposed configurations, missing Supabase RLS, and data exposure. A setup hygiene tool. 100% local.",
  "permissions": [
    "cookies",
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://lovable.dev/*",
    "https://api.lovable.dev/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
