{
  "manifest_version": 3,
  "name": "NXLV Shield — Lovable Portfolio Audit",
  "version": "2.0.0",
  "description": "Scan your Lovable.dev projects for BOLA/IDOR exposure, exposed secrets, and Supabase RLS gaps. Local-first, read-only, privacy-preserving.",
  "permissions": [
    "cookies",
    "activeTab",
    "storage",
    "sidePanel",
    "alarms"
  ],
  "host_permissions": [
    "https://lovable.dev/*",
    "https://api.lovable.dev/*",
    "https://*.supabase.co/*",
    "https://audit.nxlv.ai/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["https://lovable.dev/*", "https://*.lovable.dev/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["https://lovable.dev/*", "https://*.lovable.dev/*"]
    }
  ]
}
